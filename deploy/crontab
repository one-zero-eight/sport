# Training reminder cron jobs
# Morning run at 08:00: sends reminders for evening trainings (start >= 14:00) today
# Evening run at 19:00: sends reminders for morning trainings (start < 14:00) tomorrow
#
# Timezone is set via TZ environment variable in the cron service (Europe/Moscow)

0 8  * * * cd /app && python manage.py send_training_reminders >> /proc/1/fd/1 2>&1
0 19 * * * cd /app && python manage.py send_training_reminders >> /proc/1/fd/1 2>&1
